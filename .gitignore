# =============================================================================
# Django Portfolio - .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec
MANIFEST

# --- Virtual Environment ---
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# --- Django ---


# Django secret key / local settings overrides
local_settings.py
.env
.env.*
!.env.example

# Django migrations (optional — uncomment if you prefer not to track them)
# */migrations/*.py
# !*/migrations/__init__.py

# --- Logs ---
*.log
logs/

# --- macOS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon

# --- Editors & IDEs ---
# VS Code
.vscode/
*.code-workspace

# PyCharm / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.#*

# --- Testing & Coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# --- Type Checking ---
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# --- Distribution / Packaging ---
*.tar.gz
*.zip
*.rar
*.7z

# --- Jupyter Notebooks ---
.ipynb_checkpoints/

# --- Node (if any frontend tooling is added later) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
